<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <title>申遗丝绸之路</title>
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta name="viewport" content="initial-scale=1.0, user-scalable=no">
    <style>
        html,
        body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
        }
        #map_container {
            width: 100%;
            height: 100%;
            margin: 0;
        }
    </style>

    <script src="//api.map.baidu.com/api?v=1.0&type=webgl&ak=DLWm40m6Ko1nVJ9Es3qQRwn8zorGK0si"></script>
    <script src="https://mapv.baidu.com/gl/examples/static/common.js"></script>
    <script src="//mapv.baidu.com/build/mapv.min.js"></script>
    <script src="https://code.bdstatic.com/npm/mapvgl@1.0.0-beta.189/dist/mapvgl.min.js"></script>

</head>
<body>
<div id="map_container"></div>
<script>
    var map = initMap({
        tilt: 49.6,
        heading: 0,
        center: [95.,41],
        zoom: 5,
        style: whiteStyle,
        skyColors: [
            'rgba(226, 237, 248, 0)',
            'rgba(186, 211, 252, 1)'
        ]
    });

    var view = new mapvgl.View({
        map: map
    });
    //


            // 获取第二个 JSON 文件的数据
    fetch('申遗丝绸之路.json')
        .then(response => response.json())
        .then(json => {
            // 遍历 paths[] 的值
            for (let i = 0; i < 20; i++) {
                // 合并数据并转换数据格式
                var data = json.features.map(feature => {
                    return {
                        geometry: {
                            type: 'LineString',
                            coordinates: feature.geometry.paths[i]//.reverse()
                        }
                    };
                });

                console.log('data' + (i + 1), data);

                // 创建图层
                var layer = new mapvgl.WallLayer({
                    gradient: {
                        0: 'rgba(70, 191, 191, 0.6)',
                        1: 'rgba(23, 63, 63, 0.8)'
                    },
                    height: 100000,
                    data:data
                });

                // 将图层添加到视图
                view.addLayer(layer);


            }
        })




        .catch(error => {
            console.error('Error loading JSON:', error);
        });



</script>
</body>
</html>
